# Example environment variables for scripts/withdraw_guardian.py
# Copy this to a file named .env in the repo or set secrets in CI.

RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
CONTRACT_ADDRESS=0xYourContractAddress
THRESHOLD_ETH=0.01
CHAIN_ID=11155111
GAS_LIMIT=200000
RETRIES=1
WAIT_SECONDS=10
# Set DRY_RUN=true to test without sending transactions
DRY_RUN=true
